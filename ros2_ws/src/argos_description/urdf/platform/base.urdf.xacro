<?xml version="1.0"?>
<!--
  ARGOS UGV 플랫폼 계층
  =======================
  섀시(base_link) + 4개 바퀴 + 센서 플랫폼.
  이 파일은 로봇의 "몸체"만 정의. 센서와 컨트롤러는 별도 xacro.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 치수 파라미터 로드 -->
  <xacro:include filename="$(find argos_description)/urdf/platform/dimensions.xacro"/>

  <!-- ============================================================ -->
  <!--  관성 매크로 (box, cylinder)                                    -->
  <!-- ============================================================ -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (y*y + z*z) / 12.0}" ixy="0" ixz="0"
        iyy="${m * (x*x + z*z) / 12.0}" iyz="0"
        izz="${m * (x*x + y*y) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${m * (3*r*r + h*h) / 12.0}" ixy="0" ixz="0"
        iyy="${m * (3*r*r + h*h) / 12.0}" iyz="0"
        izz="${m * r * r / 2.0}"/>
    </inertial>
  </xacro:macro>

  <!-- ============================================================ -->
  <!--  base_footprint (지면 투영)                                     -->
  <!-- ============================================================ -->
  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius + ground_clearance}" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!--  base_link (메인 섀시)                                          -->
  <!-- ============================================================ -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="argos_red"/>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${base_mass}" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <!-- Gazebo 색상 (Gazebo는 URDF material 무시, 별도 지정 필요) -->
  <gazebo reference="base_link">
    <material>
      <ambient>0.8 0.1 0.1 1.0</ambient>
      <diffuse>0.8 0.1 0.1 1.0</diffuse>
    </material>
  </gazebo>

  <!-- ============================================================ -->
  <!--  센서 플랫폼 (base_link 위 상판)                                -->
  <!-- ============================================================ -->
  <link name="sensor_platform_link">
    <visual>
      <geometry>
        <box size="0.30 0.30 ${sensor_platform_height}"/>
      </geometry>
      <material name="argos_dark"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.30 0.30 ${sensor_platform_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="0.5" x="0.30" y="0.30" z="${sensor_platform_height}"/>
  </link>

  <joint name="sensor_platform_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_platform_link"/>
    <origin xyz="0 0 ${sensor_platform_z}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="sensor_platform_link">
    <material>
      <ambient>0.15 0.15 0.15 1.0</ambient>
      <diffuse>0.15 0.15 0.15 1.0</diffuse>
    </material>
  </gazebo>

  <!-- ============================================================ -->
  <!--  바퀴 매크로                                                    -->
  <!-- ============================================================ -->
  <xacro:macro name="wheel" params="prefix x_pos y_pos">
    <link name="${prefix}_wheel_link">
      <visual>
        <!-- 바퀴는 Y축 실린더 → 눕히기 위해 roll 90도 -->
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="argos_dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_width}"/>
    </link>

    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="${x_pos} ${y_pos} ${-ground_clearance}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.1" friction="0.1"/>
    </joint>

    <gazebo reference="${prefix}_wheel_link">
      <material>
        <ambient>0.15 0.15 0.15 1.0</ambient>
        <diffuse>0.15 0.15 0.15 1.0</diffuse>
      </material>
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
    </gazebo>
  </xacro:macro>

  <!-- 4개 바퀴 인스턴스 -->
  <xacro:wheel prefix="front_left"  x_pos="${wheel_x_offset}"  y_pos="${wheel_y_offset}"/>
  <xacro:wheel prefix="front_right" x_pos="${wheel_x_offset}"  y_pos="${-wheel_y_offset}"/>
  <xacro:wheel prefix="rear_left"   x_pos="${-wheel_x_offset}" y_pos="${wheel_y_offset}"/>
  <xacro:wheel prefix="rear_right"  x_pos="${-wheel_x_offset}" y_pos="${-wheel_y_offset}"/>

</robot>
