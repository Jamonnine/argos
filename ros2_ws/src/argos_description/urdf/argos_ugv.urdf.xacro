<?xml version="1.0"?>
<!--
  ARGOS UGV 최상위 조립 파일
  ============================
  이 파일은 include 전용 — 로직 없음, 조합만.
  센서를 추가/제거하려면 아래 include 줄을 주석처리하면 됨.

  구조:
    Platform (base + wheels)
    └─ Sensors (LiDAR, cameras, IMU)
    └─ Control (ros2_control + diff_drive)
-->
<robot name="argos_ugv" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ===== 파라미터 ===== -->
  <xacro:arg name="use_sim" default="true"/>
  <xacro:arg name="namespace" default=""/>
  <xacro:arg name="robot_name" default="argos_ugv"/>
  <xacro:property name="use_sim" value="$(arg use_sim)"/>
  <xacro:property name="ns" value="$(arg namespace)"/>
  <xacro:property name="robot_name" value="$(arg robot_name)"/>
  <!-- 네임스페이스 접두사: 비어있으면 "" / 있으면 "/ns" -->
  <xacro:property name="topic_prefix" value="${'/' + ns if ns != '' else ''}"/>

  <!-- ===== 1. Platform 계층 ===== -->
  <xacro:include filename="$(find argos_description)/urdf/platform/base.urdf.xacro"/>

  <!-- ===== 2. Sensor 계층 ===== -->
  <xacro:include filename="$(find argos_description)/urdf/sensors/lidar.urdf.xacro"/>
  <xacro:include filename="$(find argos_description)/urdf/sensors/rgb_camera.urdf.xacro"/>
  <xacro:include filename="$(find argos_description)/urdf/sensors/depth_camera.urdf.xacro"/>
  <xacro:include filename="$(find argos_description)/urdf/sensors/imu.urdf.xacro"/>
  <xacro:include filename="$(find argos_description)/urdf/sensors/thermal_camera.urdf.xacro"/>

  <!-- ===== 3. Control 계층 ===== -->
  <xacro:include filename="$(find argos_description)/urdf/control/ros2_control.urdf.xacro"/>

  <!-- ===== 센서 인스턴스화 ===== -->

  <!-- LiDAR: 센서 플랫폼 위 중앙 -->
  <xacro:lidar_sensor
    parent_link="sensor_platform_link"
    xyz="0 0 ${sensor_platform_height/2 + 0.02}"
    topic="${topic_prefix}/scan"/>

  <!-- RGB 카메라: 전방 상단 -->
  <xacro:rgb_camera
    parent_link="base_link"
    xyz="${camera_x} 0 ${camera_z}"
    camera_name="front_camera"
    topic="${topic_prefix}/camera/image_raw"/>

  <!-- 깊이 카메라: RGB 카메라 옆 (RealSense 위치) -->
  <xacro:depth_camera
    parent_link="base_link"
    xyz="${camera_x} 0.04 ${camera_z}"
    camera_name="depth_camera"
    topic="${topic_prefix}/depth_camera"/>

  <!-- IMU: 섀시 중심 -->
  <xacro:imu_sensor
    parent_link="base_link"
    xyz="0 0 0"
    topic="${topic_prefix}/imu/data"/>

  <!-- 열화상 카메라: 전방 하단 (화점 감지용) -->
  <xacro:thermal_camera
    parent_link="base_link"
    xyz="${camera_x} 0 ${-base_height/2 + 0.05}"
    camera_name="thermal_camera"
    topic="${topic_prefix}/thermal/image_raw"/>

  <!-- ===== ros2_control 인스턴스화 ===== -->
  <xacro:argos_ros2_control use_sim="${use_sim}" namespace="${ns}"/>

</robot>
